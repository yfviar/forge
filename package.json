{
  "name": "forge-terminal-mcp",
  "version": "0.8.0",
  "description": "Terminal MCP server for AI coding agents — spawn, manage, and monitor PTY sessions via MCP",
  "type": "module",
  "bin": {
    "forge": "./dist/cli.js",
    "forge-terminal-mcp": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run scripts/build-npm.ts",
    "build:binary": "bun run scripts/build-binary.ts",
    "dev": "bun run scripts/build-npm.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "desktop:dev": "npm run build && cd desktop && npm run dev",
    "desktop:build": "npm run build && cd desktop && npm run package"
  },
  "mcpName": "io.github.ferodrigop/forge-terminal",
  "keywords": [
    "mcp",
    "terminal",
    "pty",
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "gemini-cli",
    "ai-agents"
  ],
  "author": "Rodrigo Pineda",
  "homepage": "https://forgemcp.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferodrigop/forge.git"
  },
  "bugs": {
    "url": "https://github.com/ferodrigop/forge/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0",
    "ws": "^8.19.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/ws": "^8.18.1",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
